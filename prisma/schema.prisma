generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum FollowUpType {
  CALL
  EMAIL
  MEETING
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  FOLLOW_UP
  VACANCY
  HR
}

enum EmailSendStatus {
  SUCCESS
  FAILED
}

enum CompanyStatus {
  ACTIVE
  PROSPECT
  ON_HOLD
  INACTIVE
}

enum CompanySize {
  STARTUP
  SMALL
  MID_MARKET
  ENTERPRISE
}

enum HrPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum HrStatus {
  ACTIVE
  DO_NOT_CONTACT
  FOLLOW_UP
  INACTIVE
}

enum VacancyPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum VacancyStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  CLOSED
}

enum ReminderBucket {
  TODAY
  TOMORROW
  OVERDUE
  URGENT
}

enum ReminderStatus {
  UNREAD
  DONE
  DISMISSED
}

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  passwordHash  String
  fullName      String
  role          String    @default("admin")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
}

model Session {
  id         String   @id @default(cuid())
  token      String   @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Company {
  id           String        @id @default(cuid())
  name         String
  website      String?
  industry     String
  companySize  CompanySize
  city         String
  address      String?
  notes        String?
  status       CompanyStatus @default(PROSPECT)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  hrContacts   HrContact[]
  vacancies    Vacancy[]
  followUps    FollowUp[]
  activities   Activity[]
  reminders    FollowUpReminder[]

  @@unique([name, city])
  @@index([status])
  @@index([industry])
  @@index([city])
}

model HrContact {
  id                String      @id @default(cuid())
  companyId         String
  fullName          String
  email             String      @unique
  phone             String
  whatsapp          String?
  linkedIn          String?
  designation       String
  city              String
  remark            String?
  priority          HrPriority  @default(MEDIUM)
  lastContactDate   DateTime?
  nextFollowUpDate  DateTime?
  status            HrStatus    @default(ACTIVE)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  company           Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  followUps         FollowUp[]
  activities        Activity[]
  reminders         FollowUpReminder[]
  assignedVacancies Vacancy[]

  @@index([companyId])
  @@index([city])
  @@index([priority])
  @@index([status])
  @@index([nextFollowUpDate])
}

model Vacancy {
  id                  String          @id @default(cuid())
  companyId           String
  assignedRecruiterId String?
  title               String
  experience          String
  openings            Int
  location            String
  technology          String?
  skills              String?
  compensationLpa     Float
  priority            VacancyPriority @default(MEDIUM)
  status              VacancyStatus   @default(OPEN)
  remark              String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  company             Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedRecruiter   HrContact?      @relation(fields: [assignedRecruiterId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([assignedRecruiterId])
  @@index([title])
  @@index([location])
  @@index([technology])
  @@index([skills])
  @@index([priority])
  @@index([status])
}

model FollowUp {
  id           String          @id @default(cuid())
  companyId     String
  hrContactId   String?
  subject       String
  notes         String
  type          FollowUpType
  status        FollowUpStatus @default(PENDING)
  dueAt         DateTime
  completedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  hrContact     HrContact?     @relation(fields: [hrContactId], references: [id], onDelete: SetNull)
  reminder      FollowUpReminder?

  @@index([companyId])
  @@index([hrContactId])
  @@index([dueAt])
  @@index([status])
}

model Activity {
  id           String       @id @default(cuid())
  companyId     String?
  hrContactId   String?
  title         String
  description   String
  type          ActivityType
  createdAt     DateTime     @default(now())
  company       Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  hrContact     HrContact?    @relation(fields: [hrContactId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([hrContactId])
  @@index([createdAt])
}

model FollowUpReminder {
  id            String          @id @default(cuid())
  followUpId    String          @unique
  companyId     String
  hrContactId   String?
  bucket        ReminderBucket
  title         String
  description   String
  dueAt         DateTime
  scheduledFor   DateTime
  status        ReminderStatus  @default(UNREAD)
  doneAt        DateTime?
  dismissedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  followUp      FollowUp        @relation(fields: [followUpId], references: [id], onDelete: Cascade)
  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  hrContact     HrContact?      @relation(fields: [hrContactId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([hrContactId])
  @@index([bucket])
  @@index([status])
  @@index([scheduledFor])
}

model EmailSettings {
  key           String   @id
  smtpHost      String
  smtpPort      Int
  smtpSecure    Boolean  @default(true)
  smtpUser      String?
  smtpPassword  String?
  fromName      String
  fromEmail     String
  replyTo       String?
  signature     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmailTemplate {
  key         String   @id
  label       String
  subject     String
  body        String
  isDefault   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailLog {
  id            String          @id @default(cuid())
  companyId     String?
  hrContactId   String?
  templateKey   String?
  recipientName String?
  recipientEmail String
  cc            String?
  bcc           String?
  subject       String
  body          String
  status        EmailSendStatus
  errorMessage  String?
  createdAt     DateTime        @default(now())
  company       Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  hrContact     HrContact?      @relation(fields: [hrContactId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([hrContactId])
  @@index([status])
  @@index([createdAt])
}
